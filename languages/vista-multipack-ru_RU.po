msgid "Vista Multipack requires WooCommerce to be active."
msgstr "Для работы Vista Multipack должен быть активирован WooCommerce."

msgid "Enable set purchase"
msgstr "Включить продажу комплектом"

msgid "Shows a separate set price and set purchase button."
msgstr "Показывает отдельную цену комплекта и кнопку заказа комплекта."

msgid "Units per set"
msgstr "Количество единиц в комплекте"

msgid "The real WooCommerce quantity added for one set."
msgstr "Фактическое количество товара WooCommerce, добавляемое как один комплект."

msgid "Set price"
msgstr "Цена комплекта"

msgid "Total price for one complete set. The set offer remains hidden until this price is set."
msgstr "Общая цена полного комплекта. Пока цена не указана, предложение комплекта скрыто."

msgid "Vista Multipack feed integration was verified with XML for Google Merchant Center 4.3.0. Installed version: %s. Regenerate and validate the feed after updates."
msgstr "Интеграция Vista Multipack проверена с XML for Google Merchant Center 4.3.0. Установленная версия: %s. После обновления пересоздайте и проверьте фид."

msgid "Set of %d unit"
msgid_plural "Set of %d units"
msgstr[0] "Комплект из %d единицы"
msgstr[1] "Комплект из %d единиц"
msgstr[2] "Комплект из %d единиц"

msgid "Set (%1$d units) — %2$s"
msgstr "Комплект (%1$d ед.) — %2$s"

msgid "This set offer is no longer available."
msgstr "Это предложение комплекта больше недоступно."

msgid "There is not enough stock for the selected number of sets."
msgstr "Недостаточно товара для выбранного количества комплектов."

msgid "Purchase option"
msgstr "Вариант покупки"

msgid "Set"
msgstr "Комплект"

msgid "per set"
msgstr "за комплект"

msgid "%d unit total"
msgid_plural "%d units total"
msgstr[0] "всего %d единица"
msgstr[1] "всего %d единицы"
msgstr[2] "всего %d единиц"

msgid "%1$d set(s) × %2$d units"
msgstr "%1$d компл. × %2$d ед."

msgid "A set quantity was changed to an invalid number of units. Please remove it and add the set again."
msgstr "Количество комплекта изменено на некорректное количество единиц. Удалите его и добавьте комплект снова."

msgid "%1$d × %2$d units"
msgstr "%1$d × %2$d ед."

msgid "%1$s — Set of %2$d"
msgstr "%1$s — Комплект из %2$d ед."

msgid "This offer contains %d identical unit."
msgid_plural "This offer contains %d identical units."
msgstr[0] "Это предложение содержит %d одинаковую единицу товара."
msgstr[1] "Это предложение содержит %d одинаковые единицы товара."
msgstr[2] "Это предложение содержит %d одинаковых единиц товара."
