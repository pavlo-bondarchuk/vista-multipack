"Project-Id-Version: Vista Multipack 1.0.0\n"
"Language: ru_RU\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=3; plural=(n%10==1 && n%100!=11 ? 0 : n%10>=2 && n%10<=4 && (n%100<10 || n%100>=20) ? 1 : 2);\n"

msgid "Vista Multipack requires WooCommerce to be active."
msgstr "Для работы Vista Multipack должен быть активирован WooCommerce."

msgid "Enable pack purchase"
msgstr "Включить продажу упаковкой"

msgid "Shows a separate pack price and pack purchase button."
msgstr "Показывает отдельную цену упаковки и кнопку заказа упаковки."

msgid "Units per pack"
msgstr "Количество единиц в упаковке"

msgid "The real WooCommerce quantity added for one pack."
msgstr "Фактическое количество товара WooCommerce, добавляемое как одна упаковка."

msgid "Pack price"
msgstr "Цена упаковки"

msgid "Total price for one complete pack. The pack offer remains hidden until this price is set."
msgstr "Общая цена полной упаковки. Пока цена не указана, предложение упаковки скрыто."

msgid "Vista Multipack feed integration was verified with XML for Google Merchant Center 4.3.0. Installed version: %s. Regenerate and validate the feed after updates."
msgstr "Интеграция Vista Multipack проверена с XML for Google Merchant Center 4.3.0. Установленная версия: %s. После обновления пересоздайте и проверьте фид."

msgid "Pack of %d unit"
msgid_plural "Pack of %d units"
msgstr[0] "Упаковка из %d единицы"
msgstr[1] "Упаковка из %d единиц"
msgstr[2] "Упаковка из %d единиц"

msgid "%s per unit in a pack"
msgstr "%s за единицу в упаковке"

msgid "Order pack (%1$d units) — %2$s"
msgstr "Заказать упаковку (%1$d ед.) — %2$s"

msgid "This pack offer is no longer available."
msgstr "Это предложение упаковки больше недоступно."

msgid "There is not enough stock for the selected number of packs."
msgstr "Недостаточно товара для выбранного количества упаковок."

msgid "Purchase option"
msgstr "Вариант покупки"

msgid "Pack"
msgstr "Упаковка"

msgid "per pack"
msgstr "за упаковку"

msgid "%d unit total"
msgid_plural "%d units total"
msgstr[0] "всего %d единица"
msgstr[1] "всего %d единицы"
msgstr[2] "всего %d единиц"

msgid "%1$d pack(s) × %2$d units"
msgstr "%1$d уп. × %2$d ед."

msgid "A pack quantity was changed to an invalid number of units. Please remove it and add the pack again."
msgstr "Количество упаковки изменено на некорректное количество единиц. Удалите её и добавьте упаковку снова."

msgid "%1$d × %2$d units"
msgstr "%1$d × %2$d ед."

msgid "%1$s — Pack of %2$d"
msgstr "%1$s — Упаковка из %2$d ед."

msgid "This offer contains %d identical unit."
msgid_plural "This offer contains %d identical units."
msgstr[0] "Это предложение содержит %d одинаковую единицу товара."
msgstr[1] "Это предложение содержит %d одинаковые единицы товара."
msgstr[2] "Это предложение содержит %d одинаковых единиц товара."
