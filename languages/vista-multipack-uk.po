msgid "Vista Multipack requires WooCommerce to be active."
msgstr "Для роботи Vista Multipack має бути активований WooCommerce."

msgid "Enable set purchase"
msgstr "Увімкнути продаж комплектом"

msgid "Shows a separate set price and set purchase button."
msgstr "Показує окрему ціну комплекту та кнопку замовлення комплекту."

msgid "Units per set"
msgstr "Кількість одиниць у комплекті"

msgid "The real WooCommerce quantity added for one set."
msgstr "Фактична кількість товару WooCommerce, яка додається як один комплект."

msgid "Set price"
msgstr "Ціна комплекту"

msgid "Total price for one complete set. The set offer remains hidden until this price is set."
msgstr "Загальна ціна повного комплекту. Поки ціна не задана, пропозиція комплекту прихована."

msgid "Vista Multipack feed integration was verified with XML for Google Merchant Center 4.3.0. Installed version: %s. Regenerate and validate the feed after updates."
msgstr "Інтеграцію Vista Multipack перевірено з XML for Google Merchant Center 4.3.0. Встановлена версія: %s. Після оновлення перегенеруйте та перевірте фід."

msgid "Set of %d unit"
msgid_plural "Set of %d units"
msgstr[0] "Комплект з %d одиниці"
msgstr[1] "Комплект з %d одиниць"
msgstr[2] "Комплект з %d одиниць"

msgid "Order set — %s"
msgstr "Замовити комплект — %s"

msgid "This set offer is no longer available."
msgstr "Ця пропозиція комплекту більше не доступна."

msgid "There is not enough stock for the selected number of sets."
msgstr "Недостатньо товару для вибраної кількості комплектів."

msgid "Purchase option"
msgstr "Варіант покупки"

msgid "Set"
msgstr "Комплект"

msgid "per set"
msgstr "за комплект"

msgid "%d unit total"
msgid_plural "%d units total"
msgstr[0] "усього %d одиниця"
msgstr[1] "усього %d одиниці"
msgstr[2] "усього %d одиниць"

msgid "%1$d set(s) × %2$d units"
msgstr "%1$d компл. × %2$d од."

msgid "A set quantity was changed to an invalid number of units. Please remove it and add the set again."
msgstr "Кількість комплекту змінено на некоректну кількість одиниць. Видаліть його та додайте комплект знову."

msgid "%1$d × %2$d units"
msgstr "%1$d × %2$d од."

msgid "%1$s — Set of %2$d"
msgstr "%1$s — Комплект з %2$d од."

msgid "This offer contains %d identical unit."
msgid_plural "This offer contains %d identical units."
msgstr[0] "Ця пропозиція містить %d однакову одиницю товару."
msgstr[1] "Ця пропозиція містить %d однакові одиниці товару."
msgstr[2] "Ця пропозиція містить %d однакових одиниць товару."
